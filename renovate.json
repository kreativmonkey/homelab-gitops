{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "flux": {
    "enabled": true
  },
  "helm-values": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": [
        "flux"
      ],
      "groupName": "flux helm releases",
      "groupSlug": "flux-helm-releases",
      "stabilityDays": 7,
      "automerge": false
    },
    {
      "matchManagers": [
        "helm-values"
      ],
      "groupName": "helm chart versions",
      "groupSlug": "helm-chart-versions",
      "stabilityDays": 7,
      "automerge": false
    },
    {
      "matchManagers": [
        "nix",
        "lockFileMaintenance"
      ],
      "groupName": "nix packages",
      "automerge": true
    }
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10
}
