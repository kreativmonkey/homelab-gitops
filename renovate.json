{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "flux": {
    "enabled": true
  },
  "helm-values": {
    "enabled": true,
    "fileMatch": [
      "\\.yaml$",
      "\\.yml$"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "CloudNativePG PostgreSQL image in Cluster CR",
      "fileMatch": [
        "infrastructure/overlays/.*/database-clusters/.*\\.yaml$"
      ],
      "matchStrings": [
        "imageName:\\s*ghcr\\.io/cloudnative-pg/postgresql:(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/cloudnative-pg/postgresql",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "CNPG operator image tag in HelmRelease values",
      "fileMatch": [
        "infrastructure/.*/database/cnpg/helmrelease\\.yaml$"
      ],
      "matchStrings": [
        "tag:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/cloudnative-pg/cloudnative-pg",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "CI workflow action versions (Forgejo and GitHub)",
      "fileMatch": [
        "^\\.(forgejo|github)/workflows/.*\\.ya?ml$"
      ],
      "matchStrings": [
        "uses:\\s*(?<depName>[^@\\s]+)@(?<currentValue>[^\\s#]+)"
      ],
      "datasourceTemplate": "github-tags"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "flux"
      ],
      "groupName": "flux helm releases",
      "groupSlug": "flux-helm-releases",
      "stabilityDays": 7,
      "automerge": false
    },
    {
      "matchManagers": [
        "helm-values"
      ],
      "groupName": "helm chart versions",
      "groupSlug": "helm-chart-versions",
      "stabilityDays": 7,
      "automerge": false
    },
    {
      "matchManagers": [
        "nix",
        "lockFileMaintenance"
      ],
      "groupName": "nix packages",
      "automerge": true
    },
    {
      "description": "Auto-merge patch updates for low-risk dashboards",
      "matchManagers": [
        "flux",
        "docker"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "matchPaths": [
        "apps/base/homepage/**",
        "apps/base/uptime-kuma/**"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10
}
