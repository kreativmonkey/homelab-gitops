{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "flux": {
    "enabled": true
  },
  "helm-values": {
    "enabled": true,
    "managerFilePatterns": [
      "/\\.yaml$/",
      "/\\.yml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "CloudNativePG PostgreSQL image in Cluster CR",
      "managerFilePatterns": [
        "/infrastructure/overlays/.*/database-clusters/.*\\.yaml$/"
      ],
      "matchStrings": [
        "imageName:\\s*ghcr\\.io/cloudnative-pg/postgresql:(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/cloudnative-pg/postgresql",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "CNPG operator image tag in HelmRelease values",
      "managerFilePatterns": [
        "/infrastructure/.*/database/cnpg/helmrelease\\.yaml$/"
      ],
      "matchStrings": [
        "tag:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/cloudnative-pg/cloudnative-pg",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "n8n container image tag in HelmRelease",
      "managerFilePatterns": [
        "/apps/base/n8n/helmrelease\\.yaml$/"
      ],
      "matchStrings": [
        "tag:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "n8nio/n8n",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Talos version in System Upgrade Controller Plan",
      "managerFilePatterns": [
        "/infrastructure/overlays/main/system-upgrade-controller/talos-plan\\.yaml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)( versioning=(?<versioning>[^\\s]+))?\\s+version:\\s*(?<currentValue>v[^\\s]+)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "description": "CI workflow action versions (Forgejo and GitHub)",
      "managerFilePatterns": [
        "/^\\.(forgejo|github)/workflows/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "uses:\\s*(?:https://github\\.com/)?(?<depName>[^@\\s/]+/[^@\\s]+)@(?<currentValue>[^\\s#]+)"
      ],
      "datasourceTemplate": "github-tags"
    }
  ],
  "packageRules": [
    {
      "description": "Kite: bump Helm chart via flux only (appVersion sets container image)",
      "matchFileNames": [
        "apps/base/kite/**"
      ],
      "matchManagers": [
        "flux"
      ],
      "groupName": "kite",
      "groupSlug": "kite",
      "minimumReleaseAge": "3 days",
      "automerge": false
    },
    {
      "description": "Do not let helm-values override kite image tag out of sync with chart",
      "matchFileNames": [
        "apps/base/kite/**"
      ],
      "matchManagers": [
        "helm-values"
      ],
      "enabled": false
    },
    {
      "matchManagers": [
        "flux"
      ],
      "matchFileNames": [
        "!apps/base/kite/**"
      ],
      "groupName": "flux helm releases",
      "groupSlug": "flux-helm-releases",
      "minimumReleaseAge": "7 days",
      "automerge": false
    },
    {
      "matchManagers": [
        "helm-values"
      ],
      "matchFileNames": [
        "!apps/base/kite/**"
      ],
      "groupName": "helm chart versions",
      "groupSlug": "helm-chart-versions",
      "minimumReleaseAge": "7 days",
      "automerge": false
    },
    {
      "matchManagers": [
        "nix",
        "lockFileMaintenance"
      ],
      "groupName": "nix packages",
      "automerge": true
    },
    {
      "description": "Group Talos SUC Plan with other Talos release bumps",
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["siderolabs/talos"],
      "matchFileNames": [
        "infrastructure/overlays/main/system-upgrade-controller/**"
      ],
      "groupName": "talos linux",
      "automerge": false
    },
    {
      "description": "Auto-merge patch updates for low-risk dashboards",
      "matchManagers": [
        "flux",
        "docker"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "matchFileNames": [
        "apps/base/homepage/**",
        "apps/base/uptime-kuma/**"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10
}
