{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "kubernetes": {
    "enabled": true,
    "managerFilePatterns": [
      "/apps/.*\\.yaml$/",
      "/apps/.*\\.yml$/"
    ],
    "matchPackagePatterns": [
      "*"
    ]
  },
  "flux": {
    "enabled": true
  },
  "helm-values": {
    "enabled": true
  },
  "regex": {
    "enabled": true,
    "managerFilePatterns": [
      "/Dockerfile$/"
    ],
    "matchStrings": [
      "image:(?<depName>.*?):(?<currentValue>.*?)(?:#|$)"
    ]
  },
  "packageRules": [
    {
      "matchManagers": [
        "flux"
      ],
      "groupName": "flux helm releases",
      "groupSlug": "flux-helm-releases",
      "stabilityDays": 7,
      "automerge": false
    },
    {
      "matchManagers": [
        "helm-values"
      ],
      "groupName": "helm chart versions",
      "groupSlug": "helm-chart-versions",
      "stabilityDays": 7,
      "automerge": false
    },
    {
      "matchManagers": [
        "kubernetes"
      ],
      "groupName": "app container images",
      "groupSlug": "app-container-images",
      "stabilityDays": 3,
      "automerge": false
    },
    {
      "matchManagers": [
        "regex"
      ],
      "groupName": "dockerfiles",
      "automerge": false
    },
    {
      "matchManagers": [
        "nix"
      ],
      "groupName": "nix dependencies",
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "matchPackagePrefixes": [
        "b4bz/homer",
        "kiteproxy/kite",
        "docspa/sterling-pdf"
      ],
      "groupName": "app images",
      "stabilityDays": 3
    }
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10
}
