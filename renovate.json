{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "kubernetes": {
    "fileMatch": ["\\.yaml$", "\\.yml$"]
  },
  "flux": {
    "enabled": true
  },
  "helm-values": {
    "enabled": true,
    "fileMatch": ["\\.yaml$", "\\.yml$", "(^|/)values-.+\\.yaml$", "deployment\\.yaml$"]
  },
  "packageRules": [
    {
      "matchManagers": ["kubernetes", "flux"],
      "groupName": "kubernetes dependencies",
      "automerge": false
    },
    {
      "matchManagers": ["helm-values"],
      "groupName": "helm dependencies",
      "automerge": false
    },
    {
      "matchPackagePatterns": ["*"],
      "matchManagers": ["nix"],
      "groupName": "nix dependencies"
    }
  ]
}
