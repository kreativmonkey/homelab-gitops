{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "rebaseWhen": "behind-base-branch",
  "nix": {
    "enabled": true
  },
  "kustomize": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "flux": {
    "enabled": true,
    "managerFilePatterns": [
      "/(^|/).+\\.ya?ml$/"
    ]
  },
  "helm-values": {
    "enabled": true,
    "managerFilePatterns": [
      "/(^|/).+/helmrelease\\.ya?ml$/",
      "/(^|/).+/values\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "enabled": true,
    "managerFilePatterns": [
      "/(^|/).+/(deployment|daemonset|statefulset|job|cronjob)\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Generic '# renovate: datasource=X depName=Y [versioning=Z] [extractVersion=R]' marker — covers tag-only fields (tag: vX) AND fully-qualified image refs (imageName: repo:tag, value: \"repo:tag\")",
      "managerFilePatterns": [
        "/(^|/)(apps|infrastructure|clusters)/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?(?:\\s+extractVersion=(?<extractVersion>\\S+))?\\s*\\n(?:[^\\n]*\\n)*?\\s*tag:\\s*[\"']?(?<currentValue>[^\\s\"'#]+)[\"']?\\s*(?:#.*)?",
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?(?:\\s+extractVersion=(?<extractVersion>\\S+))?\\s*\\n[^\\n]*?:\\s*[\"']?[^:\\s\"']+:(?<currentValue>[^\"'\\s]+)[\"']?\\s*(?:#.*)?",
        "\\s*tag:\\s*[\"']?(?<currentValue>[^\\s\"'#]+)[\"']?\\s*#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?(?:\\s+extractVersion=(?<extractVersion>\\S+))?\\s*"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "description": "Generic '# renovate: datasource=X depName=Y' marker for version fields",
      "managerFilePatterns": [
        "/(^|/)(apps|infrastructure|clusters)/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?(?:\\s+extractVersion=(?<extractVersion>\\S+))?\\s*\\n\\s*version:\\s*[\"']?(?<currentValue>[^\\s\"'#]+)[\"']?\\s*(?:#.*)?",
        "\\s*version:\\s*[\"']?(?<currentValue>[^\\s\"'#]+)[\"']?\\s*#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?(?:\\s+extractVersion=(?<extractVersion>\\S+))?\\s*"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "description": "Generic '# renovate: datasource=X depName=Y' marker for list items with @version",
      "managerFilePatterns": [
        "/(^|/)(apps|infrastructure|clusters)/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?(?:\\s+extractVersion=(?<extractVersion>\\S+))?\\s*\\n\\s*-\\s+[^@\\s]+@(?<currentValue>[^\\s#]+)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "description": "Grafana plugins — versions from grafana.com catalog (Grafana installs from catalog, not GitHub)",
      "managerFilePatterns": [
        "/(^|/)(apps|infrastructure|clusters)/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=custom\\.grafana-plugins\\s+depName=(?<depName>\\S+)\\s*\\n\\s*-\\s+(?<packageName>[^@\\s]+)@(?<currentValue>[^\\s#]+)"
      ],
      "datasourceTemplate": "custom.grafana-plugins",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Immich shared image.tag (values.image.tag — avoids false match on redis/bitnami tags)",
      "managerFilePatterns": [
        "/apps/base/immich/helmrelease\\.yaml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=docker depName=ghcr\\.io/immich-app/immich-server[^\\n]*\\n\\s+tag:\\s*[\"']?(?<currentValue>v[^\\s\"']+)[\"']?"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/immich-app/immich-server",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "VictoriaMetrics operator env-var images (`- name: VM_*_IMAGE` followed by `value: \"repo:tag\"`)",
      "managerFilePatterns": [
        "/(^|/)apps/base/monitoring/vm-k8s-stack/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "- name:\\s+VM_\\S+_IMAGE\\s*\\n\\s*value:\\s*[\"']?(?<depName>[^:\"'\\s]+):(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "Authentik Helm chart (CalVer YYYY.MM.P on charts.goauthentik.io)",
      "managerFilePatterns": [
        "/apps/base/authentik/helmrelease\\.yaml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=helm registryUrl=https://charts\\.goauthentik\\.io depName=authentik\\s*\\n\\s+version:\\s*[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "authentik",
      "registryUrlTemplate": "https://charts.goauthentik.io",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "CI workflow action versions (Forgejo and GitHub)",
      "managerFilePatterns": [
        "/^\\.(forgejo|github)/workflows/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "uses:\\s*(?:https://github\\.com/)?(?<depName>[^@\\s/]+/[^@\\s]+)@(?<currentValue>[^\\s#]+)"
      ],
      "datasourceTemplate": "github-tags"
    }
  ],
  "customDatasources": {
    "grafana-plugins": {
      "defaultRegistryUrlTemplate": "https://grafana.com/api/plugins/{{packageName}}/versions",
      "format": "json",
      "transformTemplates": [
        "{\"releases\": items.({\"version\": $string(version)}), \"sourceUrl\": \"https://grafana.com/grafana/plugins/{{packageName}}\"}"
      ]
    }
  },
  "packageRules": [
    {
      "description": "apache/tika: only stable 4-part numeric slim tags (no -full/-alpha/-SNAPSHOT)",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "docker.io/apache/tika"
      ],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+\\.\\d+$/"
    },
    {
      "description": "Grafana plugins: only catalog versions; short soak before bump",
      "matchManagers": [
        "custom.regex"
      ],
      "matchDatasources": [
        "custom.grafana-plugins"
      ],
      "minimumReleaseAge": "3 days",
      "automerge": false
    },
    {
      "description": "Kite: bump Helm chart via flux only (appVersion sets container image)",
      "matchFileNames": [
        "apps/base/kite/**"
      ],
      "matchManagers": [
        "flux"
      ],
      "groupName": "kite",
      "groupSlug": "kite",
      "minimumReleaseAge": "3 days",
      "automerge": false
    },
    {
      "description": "Do not let helm-values override kite image tag out of sync with chart",
      "matchFileNames": [
        "apps/base/kite/**"
      ],
      "matchManagers": [
        "helm-values"
      ],
      "enabled": false
    },
    {
      "description": "Authentik Helm chart uses CalVer (YYYY.MM.P) — dedicated PRs",
      "matchManagers": [
        "custom.regex",
        "flux"
      ],
      "matchDepNames": [
        "authentik"
      ],
      "matchFileNames": [
        "apps/base/authentik/**"
      ],
      "versioning": "loose",
      "groupName": "authentik",
      "groupSlug": "authentik",
      "minimumReleaseAge": "7 days",
      "allowedVersions": "2026.5.*",
      "automerge": false
    },
    {
      "description": "SparkyFitness: group chart ref + image tags in one PR to prevent version drift",
      "matchFileNames": [
        "apps/base/sparkyfitness/**"
      ],
      "matchManagers": [
        "flux",
        "helm-values",
        "custom.regex"
      ],
      "groupName": "sparkyfitness",
      "groupSlug": "sparkyfitness",
      "minimumReleaseAge": "7 days",
      "automerge": false
    },
    {
      "description": "Group all flux Helm chart bumps (except kite / sparkyfitness)",
      "matchManagers": [
        "flux"
      ],
      "matchFileNames": [
        "!apps/base/kite/**",
        "!apps/base/authentik/**",
        "!apps/base/sparkyfitness/**"
      ],
      "groupName": "flux helm releases",
      "groupSlug": "flux-helm-releases",
      "minimumReleaseAge": "7 days",
      "automerge": false
    },
    {
      "description": "Group all helm-values image bumps (except kite / sparkyfitness)",
      "matchManagers": [
        "helm-values"
      ],
      "matchFileNames": [
        "!apps/base/kite/**",
        "!apps/base/sparkyfitness/**"
      ],
      "groupName": "helm chart values",
      "groupSlug": "helm-chart-values",
      "minimumReleaseAge": "7 days",
      "automerge": false
    },
    {
      "description": "Group raw kubernetes Deployment image bumps",
      "matchManagers": [
        "kubernetes"
      ],
      "groupName": "kubernetes deployments",
      "groupSlug": "kubernetes-deployments",
      "minimumReleaseAge": "7 days",
      "automerge": false
    },
    {
      "description": "Group renovate marker bumps (custom.regex, except sparkyfitness)",
      "matchManagers": [
        "custom.regex"
      ],
      "matchFileNames": [
        "!apps/base/sparkyfitness/**"
      ],
      "groupName": "renovate markers",
      "groupSlug": "renovate-markers",
      "minimumReleaseAge": "7 days",
      "automerge": false
    },
    {
      "matchManagers": [
        "nix",
        "lockFileMaintenance"
      ],
      "groupName": "nix packages",
      "automerge": true
    },
    {
      "description": "Talos SUC Plan + Talos terraform inputs grouped",
      "matchManagers": [
        "custom.regex"
      ],
      "matchDepNames": [
        "siderolabs/talos"
      ],
      "groupName": "talos linux",
      "automerge": false
    },
    {
      "description": "Auto-merge patch updates for low-risk dashboards",
      "matchManagers": [
        "flux",
        "kubernetes",
        "docker"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "matchFileNames": [
        "apps/base/homepage/**",
        "apps/base/uptime-kuma/**"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10
}
