{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/\\.yaml$/",
      "/\\.yml$/"
    ]
  },
  "flux": {
    "enabled": true
  },
  "helm-values": {
    "enabled": true,
    "managerFilePatterns": [
      "/\\.yaml$/",
      "/\\.yml$/",
      "/(^|/)values-.+\\.yaml$/",
      "/deployment\\.yaml$/"
    ]
  },
  "packageRules": [
    {
      "matchManagers": [
        "kubernetes",
        "flux"
      ],
      "groupName": "kubernetes dependencies",
      "automerge": false
    },
    {
      "matchManagers": [
        "helm-values"
      ],
      "groupName": "helm dependencies",
      "automerge": false
    },
    {
      "matchManagers": [
        "nix"
      ],
      "groupName": "nix dependencies",
      "matchPackageNames": [
        "*"
      ]
    }
  ]
}
