apiVersion: v1
kind: Secret
metadata:
  name: sparkyfitness-app
  namespace: sparkyfitness
type: Opaque
stringData:
  SPARKY_FITNESS_DB_PASSWORD: REPLACE_WITH_PASSWORD
  SPARKY_FITNESS_APP_DB_PASSWORD: REPLACE_WITH_PASSWORD
  SPARKY_FITNESS_API_ENCRYPTION_KEY: REMOVED_BY_HISTORY_REWRITE
  BETTER_AUTH_SECRET: REPLACE_WITH_RANDOM_SECRET
  # OIDC (Authentik)
  SPARKY_FITNESS_OIDC_CLIENT_ID: REPLACE_WITH_CLIENT_ID
  SPARKY_FITNESS_OIDC_CLIENT_SECRET: REPLACE_WITH_CLIENT_SECRET
