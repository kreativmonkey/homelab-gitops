apiVersion: v1
kind: Secret
metadata:
  name: sparkyfitness-app-values
  namespace: sparkyfitness
type: Opaque
stringData:
  SPARKY_FITNESS_API_ENCRYPTION_KEY: REPLACE_WITH_64_HEX
  BETTER_AUTH_SECRET: REPLACE_WITH_RANDOM_SECRET
  # DB passwords live in homelab-postgres-sparkyfitness* secrets (db-secrets overlay + CNPG credentials).
  SPARKY_FITNESS_OIDC_CLIENT_ID: REPLACE_WITH_CLIENT_ID
  SPARKY_FITNESS_OIDC_CLIENT_SECRET: REPLACE_WITH_CLIENT_SECRET
