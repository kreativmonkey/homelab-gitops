#     url='http://n8n-app.ai-ops.svc.cluster.local:5678/webhook/homelab-alert?webhookSecret=SAME_AS_n8n-integration-credentials'
#
# Then add alertmanager-n8n-webhook.secret.yaml to kustomization.yaml resources.
