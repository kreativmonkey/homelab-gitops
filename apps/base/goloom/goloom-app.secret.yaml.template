# Sensitive goloom configuration (SOPS) consumed by the official Helm chart via
# secret.existingSecret=goloom-app. Keys:
#   ENCRYPTION_KEY        — decrypts stored provider tokens; MUST stay stable and
#                           match the value the data was encrypted with (prod).
#   BOOTSTRAP_ADMIN_TOKEN — one-time first-admin bootstrap token.
#   DATABASE_URL          — full CNPG DSN incl. password (chart wants one key):
#                           postgres://goloom:<pw>@homelab-postgres-rw.cnpg-system.svc.cluster.local:5432/goloom?sslmode=disable
#   OIDC_CLIENT_SECRET    — Authentik OIDC client secret.
#   OPENAI_API_KEY        — AI features.
#   GOLOOM_API_TOKEN      — app/MCP API token.
#
#   cd apps/base/goloom
#   just sops-create goloom-app goloom \
#     ENCRYPTION_KEY="..." BOOTSTRAP_ADMIN_TOKEN="..." \
#     DATABASE_URL="postgres://goloom:...@homelab-postgres-rw.cnpg-system.svc.cluster.local:5432/goloom?sslmode=disable" \
#     OIDC_CLIENT_SECRET="..." OPENAI_API_KEY="..." GOLOOM_API_TOKEN="..."
#
# Then add goloom-app.secret.yaml to kustomization.yaml.
