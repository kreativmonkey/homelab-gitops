# GitHub PAT + LLM key for GitOps auto-remediation workflow (Forgejo is backup only)
#
# GitHub: fine-grained or classic PAT with Contents + Pull requests (write) on homelab-gitops
#
#   cd apps/base/n8n
#   just sops-create n8n-integration-credentials ai-ops \
#     github-token='github_pat_xxx' \
#     llm-api-key='sk-xxx' \
#     llm-base-url='https://api.openai.com/v1'
#
# For Ollama in-cluster, set llm-base-url to e.g. http://ollama.llm.svc.cluster.local:11434/v1
#
# Then add n8n-integration-credentials.secret.yaml to kustomization.yaml resources.

apiVersion: v1
kind: Secret
metadata:
  name: n8n-integration-credentials
  namespace: ai-ops
  labels:
    app.kubernetes.io/name: n8n
    app.kubernetes.io/component: secrets
type: Opaque
stringData:
  github-token: "REPLACE_ME_GITHUB_PAT"
  llm-api-key: "REPLACE_ME_LLM_KEY"
  llm-base-url: "https://api.openai.com/v1"
