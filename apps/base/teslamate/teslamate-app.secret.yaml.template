# TeslaMate ENCRYPTION_KEY (SOPS). Required to store Tesla API tokens.
#
#   cd apps/base/teslamate
#   just sops-create teslamate-app teslamate \
#     ENCRYPTION_KEY="$(openssl rand -hex 32)"
#
# Use the same key when migrating from Docker. Then add teslamate-app.secret.yaml to kustomization.yaml.
