# Forgejo Personal Access Token used by agentgateway to call the Forgejo REST
# API on behalf of MCP tool calls (injected upstream as `Authorization: token …`).
#
# Unencrypted shape reference. The real value lives in the SOPS-encrypted
# agentgateway-forgejo.secret.yaml (encrypted_regex covers stringData).
#
# Scope: a token with only the permissions you want agents to have (read repo /
# issues is enough for the curated tool set; add write:issue for issue creation).
#
# Re-create / rotate:
#   cd apps/base/agentgateway
#   cp agentgateway-forgejo.secret.yaml.template agentgateway-forgejo.secret.yaml
#   # edit FORGEJO_TOKEN, then:
#   just sops-encrypt agentgateway-forgejo.secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: agentgateway-forgejo
  namespace: agentgateway
type: Opaque
stringData:
  FORGEJO_TOKEN: CHANGE_ME
