# S3 credentials for CNPG Barman backups (Garage/MinIO compatible)
#
# From this directory:
#   just sops-create cnpg-barman-s3-credentials cnpg-system \
#     ACCESS_KEY_ID=YOUR_KEY ACCESS_SECRET_KEY=YOUR_SECRET
#
# sops-create writes kubectl base64 data and encrypts in one step.
# Do not use stringData + manual sops-encrypt (breaks Flux: illegal base64 in data).
#
# Optional: external-secret.barman-s3.example.yaml with External Secrets Operator
