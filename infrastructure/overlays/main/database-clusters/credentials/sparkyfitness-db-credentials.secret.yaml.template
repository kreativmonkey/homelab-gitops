# CNPG bootstrap for role sparkyfitness (owner). Create with:
#   export SOPS_AGE_KEY_FILE=/path/to/cluster-age-key
#   just cnpg-db-credential sparkyfitness-db-credentials sparkyfitness 'owner-password'
# Password must match SPARKY_FITNESS_DB_PASSWORD in sparkyfitness-app-values.
apiVersion: v1
kind: Secret
metadata:
  name: sparkyfitness-db-credentials
  namespace: cnpg-system
type: Opaque
stringData:
  username: sparkyfitness
  password: REPLACE_ME
