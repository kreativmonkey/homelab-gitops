# CNPG bootstrap for role sparkyfitness_app. Create with:
#   export SOPS_AGE_KEY_FILE=/path/to/cluster-age-key
#   just cnpg-db-credential sparkyfitness-app-db-credentials sparkyfitness_app 'app-password'
# Password must match SPARKY_FITNESS_APP_DB_PASSWORD in sparkyfitness-app-values.
apiVersion: v1
kind: Secret
metadata:
  name: sparkyfitness-app-db-credentials
  namespace: cnpg-system
type: Opaque
stringData:
  username: sparkyfitness_app
  password: REPLACE_ME
